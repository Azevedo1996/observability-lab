# Observability Lab - Parte 4
TZ=America/Sao_Paulo

# Zabbix - flavor RHEL-like para imagens oficiais
ZABBIX_IMAGE_FLAVOR=ol
ZABBIX_VERSION=7.4
ZABBIX_MAJOR_VERSION=7.4

# PostgreSQL dedicado ao Zabbix
ZABBIX_POSTGRES_DB=zabbix
ZABBIX_POSTGRES_USER=zabbix
ZABBIX_POSTGRES_PASSWORD=zabbix_lab_password
ZABBIX_POSTGRES_PORT=5432

# PostgreSQL para aplicacoes de teste/lab
APP_POSTGRES_DB=appdb
APP_POSTGRES_USER=appuser
APP_POSTGRES_PASSWORD=app_lab_password
APP_POSTGRES_PORT=5433

# Portas Zabbix expostas no Windows
ZABBIX_SERVER_PORT=10051
ZABBIX_WEB_HTTP_PORT=8089
ZABBIX_WEB_HTTPS_PORT=8443
ZBX_SERVER_NAME=Observability Lab

# Ajustes basicos do Zabbix para laboratorio
ZBX_CACHESIZE=128M
ZBX_HISTORYCACHESIZE=64M
ZBX_TRENDCACHESIZE=64M
ZBX_VALUECACHESIZE=128M
ZBX_STARTPINGERS=5

# Prometheus
PROMETHEUS_VERSION=latest
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_VERSION=latest
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_lab_password
GRAFANA_INSTALL_PLUGINS=alexanderzobnin-zabbix-app

# Targets Rocky Linux 9
NODE_EXPORTER_VERSION=1.8.2
TARGET_IMAGE_VERSION=part4
